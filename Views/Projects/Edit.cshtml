@model COS4040A.Models.Project

<h2>Edit Project</h2>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="Id" />

    <div class="form-group mb-2">
        <label asp-for="Title"></label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="form-group mb-2">
        <label asp-for="Description"></label>
        <textarea asp-for="Description" class="form-control"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="form-group mb-2">
        <label asp-for="Author"></label>
        <input asp-for="Author" class="form-control" />
        <span asp-validation-for="Author" class="text-danger"></span>
    </div>

    <div class="form-group mb-2">
        <label asp-for="ProgrammingLanguage"></label>
        <input asp-for="ProgrammingLanguage" class="form-control" />
        <span asp-validation-for="ProgrammingLanguage" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Status"></label>
        <select asp-for="Status" class="form-control"
                asp-items="Html.GetEnumSelectList<COS4040A.Models.ProjectStatus>()">
        </select>
    </div>

    <button type="submit" class="btn btn-success">Save</button>

    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
        Cancel
    </a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}