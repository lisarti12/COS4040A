@model COS4040A.ViewModels.HomeIndexViewModel
@using COS4040A.Models

@{
    ViewData["Title"] = "Home Page";
    bool isLoggedIn = Context.Session.GetString("UserEmail") != null;
}

<div class="text-center mb-4">
    <h1>Welcome to e-Project</h1>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

<h3>5 Most Recently Completed Projects</h3>

@if (Model.RecentCompletedProjects.Any())
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Title</th>
                <th>Description</th>
                <th>Author</th>
                <th>Programming Language</th>
                <th>Status</th>
                <th>Completed At</th>
                @if (isLoggedIn)
                {
                    <th>Actions</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var project in Model.RecentCompletedProjects)
            {
                <tr>
                    <td>@project.Title</td>
                    <td>@project.Description</td>
                    <td>@project.Author</td>
                    <td>@project.ProgrammingLanguage</td>
                    <td>@project.Status</td>
                    <td>@project.CompletedAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>

                    @if (isLoggedIn)
                    {
                        <td>
                            <a asp-controller="Projects"
                           asp-action="Edit"
                           asp-route-id="@project.Id"
                           class="btn btn-warning btn-sm">
                            Edit
                            </a>
                        
                            @if (project.Status == ProjectStatus.Pending || project.Status == ProjectStatus.Complete)
                            {
                                <form asp-controller="Projects" asp-action="Delete" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@project.Id" />
                                    <button type="submit"
                                            class="btn btn-danger btn-sm"
                                            onclick="return confirm('Are you sure you want to delete project @project.Title?');">
                                        Delete
                                    </button>
                                </form>
                            }
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No completed projects found.</p>
}