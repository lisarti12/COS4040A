@model COS4040A.ViewModels.HomeIndexViewModel

@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center mb-4">
    <h1 class="display-5">Welcome to e-Project</h1>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success text-center">
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger text-center">
        @TempData["ErrorMessage"]
    </div>
}

<div class="mb-3">
    <h3 class="text-center">5 Most Recently Completed Projects</h3>
</div>

@if (Model.RecentCompletedProjects.Any())
{
    <div class="table-responsive">
        <table class="table table-bordered table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Author</th>
                    <th>Language</th>
                    <th>Completed</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var project in Model.RecentCompletedProjects)
                {
                    <tr>
                        <td>@project.Title</td>
                        <td>@project.Author</td>
                        <td>@project.ProgrammingLanguage</td>
                        <td>@project.CompletedAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <p class="text-center">No completed projects found.</p>
}